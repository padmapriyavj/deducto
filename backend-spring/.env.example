# ---------------------------------------------------------------------------
# Deducto Spring Boot — template only (no real secrets in git)
# Copy: cp .env.example .env  then fill in .env (gitignored)
# ---------------------------------------------------------------------------
# Supabase API URL: https://YOUR_PROJECT_REF.supabase.co
# JDBC host must be: db.YOUR_PROJECT_REF.supabase.co
# ---------------------------------------------------------------------------

# --- Database (JDBC) ---
# Replace YOUR_PROJECT_REF with your Supabase project ref (Settings → General).
#   DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Almost always:
DB_USERNAME=postgres
# Set in Supabase: Project Settings → Database → Database password (reset if needed)
# This is NOT your anon key or service_role key.
DB_PASSWORD=

# --- JWT (signing tokens; use a long random string in production) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- AWS S3 (Phase 3+ materials) ---
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- OpenAI / LLM (Spring AI; see application.yml) ---
OPENAI_API_KEY=
# Optional; only if you use Gemini elsewhere
GEMINI_API_KEY=
LLM_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Optional — not read by application.yml today
# ---------------------------------------------------------------------------
