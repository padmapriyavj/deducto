# ---------------------------------------------------------------------------
# Deducto Spring Boot — template only (no real secrets in git)
# Copy: cp .env.example .env  then fill in .env (gitignored)
# ---------------------------------------------------------------------------
# Supabase API URL: https://YOUR_PROJECT_REF.supabase.co
# JDBC host must be: db.YOUR_PROJECT_REF.supabase.co
# ---------------------------------------------------------------------------

# --- Database (JDBC) ---
# Replace YOUR_PROJECT_REF with your Supabase project ref (Settings → General).
#   DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Almost always:
DB_USERNAME=postgres
# Set in Supabase: Project Settings → Database → Database password (reset if needed)
# This is NOT your anon key or service_role key.
DB_PASSWORD=

# --- JWT (signing tokens; use a long random string in production) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- AWS S3 (Phase 3+ materials) ---
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- LLM (Spring AI: spring-ai-openai client; see application.yml) ---
# OpenAI: set OPENAI_API_KEY and an OpenAI model; leave GROQ_API_KEY and OPENAI_BASE_URL unset.
# Groq: set GROQ_API_KEY, OPENAI_BASE_URL=https://api.groq.com/openai, LLM_MODEL to a Groq model id.
#   If you also have OPENAI_API_KEY in .env, remove it or the app will prefer GROQ_API_KEY (see application.yml).
OPENAI_BASE_URL=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=gpt-4o
#
# Spring Boot does not load this file automatically. For `./mvnw spring-boot:run` in a shell, export first, e.g.:
#   set -a && source .env && set +a && ./mvnw spring-boot:run
# or load env vars in your IDE run configuration.

# ---------------------------------------------------------------------------
# Optional — not read by application.yml today
# ---------------------------------------------------------------------------
